# ─── Sanity CMS ───────────────────────────────────────────────────────────────
SANITY_PROJECT_ID=
SANITY_DATASET=production
# Write token — server-side API routes only. NEVER expose in client code.
SANITY_API_TOKEN=

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
# Service-role key — bypasses Row-Level Security. Server-side only. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=
# Anon/public key — safe for browser use with RLS enabled (reserved for future use)
SUPABASE_ANON_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_SERVICE_API_KEY=

# ─── Cloudflare Turnstile (bot protection) ────────────────────────────────────
# Site key — safe to expose in the browser
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
# Secret key — server-side only. NEVER expose in client code.
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# ─── Internal API ─────────────────────────────────────────────────────────────
# Random 32+ character secret used to authenticate internal API routes (e.g. inventory)
# Generate with: openssl rand -hex 32
API_SECRET_KEY=
